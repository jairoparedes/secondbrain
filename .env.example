# =========================================
# Second Brain - variables de entorno globales
# Copiar a .env: cp .env.example .env
# =========================================

# --- App general ---
APP_NAME=SecondBrain
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=

# --- Puertos expuestos en host ---
HTTP_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Base de datos (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=secondbrain
DB_USERNAME=secondbrain
DB_PASSWORD=secondbrain_dev_change_me

# --- Redis ---
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Cola y cache ---
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# --- MinIO (S3-compatible) ---
AWS_ACCESS_KEY_ID=secondbrain
AWS_SECRET_ACCESS_KEY=secondbrain_dev_change_me
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=secondbrain
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- JWT ---
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# --- IA / Embeddings ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_APP_NAME=SecondBrain
